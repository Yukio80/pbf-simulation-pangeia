# Projeto Pangeia - Environment Configuration

# Persistence
PANGEIA_PERSISTENCE=in_memory    # in_memory or postgres
PANGEIA_DATABASE_URL=postgresql://pangeia:pangeia@localhost:5432/pangeia
PANGEIA_SNAPSHOT_INTERVAL=50
PANGEIA_RECORD_ACTIONS=0

# Simulation
PANGEIA_POPULATION=500
PANGEIA_SEED=42
PANGEIA_TICK_INTERVAL=0.1